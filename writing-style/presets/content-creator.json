{
  "_meta": {
    "version": "1.0.0",
    "preset_name": "content-creator",
    "description": "Style configuration for social media and digital content creation. Conversational, hook-driven, and platform-aware with strong personal voice.",
    "typical_user": "Content creators, newsletter writers, social media managers, and thought leaders"
  },
  "primary_register": "conversational-collegial",
  "secondary_registers": ["social-thread", "newsletter-epistolary"],
  "accent_registers": ["popularizing-explainer", "narrative-storytelling"],
  "anti_registers": ["academic-analytical", "legal-regulatory", "corporate-institutional"],
  "dimensions": {
    "formality": 4.5,
    "density": 2,
    "warmth": 4,
    "pace": 4,
    "structure": 4,
    "voice_person": 5,
    "authority": 3.5,
    "abstraction": 2,
    "playfulness": 4,
    "context_dependence": 3
  },
  "not_constraints": [
    "casual but not sloppy or unprofessional",
    "accessible but not oversimplified",
    "warm but not gushing or sentimental",
    "concise but not curt or cryptic",
    "structured and scannable but not fragmented or list-obsessed",
    "personal and direct but not self-absorbed",
    "authoritative but not arrogant or dogmatic",
    "concrete and grounded but not unable to generalize",
    "playful but not flippant or try-hard"
  ],
  "context_switches": {
    "twitter_threads": {
      "primary": "social-thread",
      "modifiers": {
        "pace": 5,
        "structure": 5,
        "formality": 5,
        "playfulness": 4,
        "density": 1.5
      }
    },
    "newsletter": {
      "primary": "newsletter-epistolary",
      "modifiers": {
        "warmth": 4.5,
        "voice_person": 5,
        "pace": 3,
        "structure": 3.5,
        "formality": 4
      }
    },
    "linkedin": {
      "primary": "conversational-collegial",
      "modifiers": {
        "formality": 3,
        "authority": 4,
        "warmth": 3.5,
        "structure": 4,
        "pace": 4
      }
    },
    "youtube_scripts": {
      "primary": "oral-presentational",
      "modifiers": {
        "warmth": 4,
        "pace": 3.5,
        "playfulness": 4,
        "voice_person": 5,
        "formality": 4.5
      }
    },
    "blog_posts": {
      "primary": "popularizing-explainer",
      "modifiers": {
        "warmth": 4,
        "voice_person": 5,
        "pace": 3,
        "structure": 3.5,
        "playfulness": 3.5
      }
    },
    "instagram_captions": {
      "primary": "caption-micro",
      "modifiers": {
        "pace": 5,
        "playfulness": 4.5,
        "warmth": 4,
        "formality": 5,
        "structure": 5
      }
    }
  },
  "blending": {
    "primary_modifier": {
      "description": "Conversational-Collegial as base: warm, peer-level, with strong personal voice. Platform-adapted through context switching.",
      "base": "conversational-collegial",
      "modifiers": {
        "formality": 4.5,
        "density": 2,
        "warmth": 4,
        "pace": 4,
        "structure": 4,
        "voice_person": 5,
        "authority": 3.5,
        "abstraction": 2,
        "playfulness": 4,
        "context_dependence": 3
      }
    },
    "context_switching": {
      "description": "Heavy context-switching across platforms while maintaining recognizable personal voice.",
      "consistent_traits": [
        "strong first-person voice everywhere",
        "hook-driven openings in all formats",
        "warmth and approachability are non-negotiable",
        "playfulness is present but calibrated per platform"
      ]
    },
    "not_constraints": {
      "description": "Guardrails to keep content authentic and substantive.",
      "constraints": [
        "casual but not sloppy or unprofessional",
        "playful but not flippant or try-hard",
        "personal but not self-absorbed"
      ]
    }
  }
}
