{
  "_comment": "Claude Code settings — copy to ~/.claude/settings.json. Plugin-specific permissions (mcp__plugin_*) activate after you install the corresponding plugins in Step 5.",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "LS",
      "NotebookRead",
      "NotebookEdit",
      "TodoRead",
      "TodoWrite",
      "Skill(brainstorming)",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_claude-mem_mcp-search__save_memory",
      "mcp__plugin_claude-mem_mcp-search__get_observations",
      "mcp__plugin_claude-mem_mcp-search__search",
      "mcp__plugin_claude-mem_mcp-search__save_observation",
      "mcp__plugin_claude-mem_mcp-search__timeline"
    ],
    "deny": [],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cleanup-claude-mem-files.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/advisor-nudge.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/suggest-compact.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/block-junk-docs.js\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/validate-artifact.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/warn-console-log.js\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "effortLevel": "high",
  "autoUpdates": true
}
